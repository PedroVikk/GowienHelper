# ===== App =====
APP_NAME=GowienHelper
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1

# ===== Security =====
SECRET_KEY=change-me-in-production-use-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=10080
ALGORITHM=HS256

# ===== Database =====
DATABASE_URL=postgresql+psycopg2://gowien:gowien@localhost:5432/gowien

# ===== AI Provider =====
# Qual provider usar: ollama | openai | anthropic | gemini
AI_PROVIDER=ollama

# --- Ollama ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:8b
OLLAMA_EMBED_MODEL=nomic-embed-text

# --- Outros providers (futuro) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# ===== Vector Store (ChromaDB) =====
CHROMA_HOST=localhost
CHROMA_PORT=8001

# ===== Storage =====
STORAGE_DIR=./storage
